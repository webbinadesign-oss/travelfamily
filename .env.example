# ─────────────────────────────────────────────────────────────
# Webbina Travel AI — Backend services environment
# Copy this file to ".env" and fill in your OWN keys.
# NEVER commit ".env".  NEVER paste real keys in chat / commits.
# If a key has ever been exposed, ROTATE it at the provider.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=8787
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── OpenAI (Webbina's reasoning / brain) ────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── ElevenLabs (voice: TTS + Conversational AI agent) ───────
ELEVENLABS_API_KEY=
# Webbina's conversational agent (identifier, not a secret)
ELEVENLABS_AGENT_ID=agent_0001kt43rqqte7ks86mzvavmacjs
# Default TTS voice id (set to Webbina's cloned voice when ready)
ELEVENLABS_VOICE_ID=

# ── Amadeus (flights & hotels) — not defined yet ────────────
# Use the self-service test environment first.
AMADEUS_ENV=test
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# ── Google Cloud (Places, Geocoding, Maps) ──────────────────
GOOGLE_CLOUD_API_KEY=

# ── OpenWeather ─────────────────────────────────────────────
OPENWEATHER_API_KEY=

# ── Supabase (persistence) ──────────────────────────────────
# IMPORTANT: the anon key is the only key safe for clients.
# Keep any service_role / secret key SERVER-SIDE ONLY.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Booking.com Demand API ──────────────────────────────────
BOOKING_API_URL=https://demandapi.booking.com/3.2
BOOKING_API_KEY=

# ── ExchangeRate (currency conversion) ──────────────────────
EXCHANGERATE_API_KEY=
